{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Frontend (Vue 3 + Vite)",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "port": 3000,
      "cwd": "frontend"
